 # SMTP Configuration
# Database Configuration
DATABASE_URL=
DATABASE_USERNAME=
DATABASE_PASSWORD=

# JPA Configuration
JPA_SHOW_SQL=false

# File Upload Configuration
UPLOAD_LOCATION=./uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,image/jpeg,image/png

# JWT Configuration
JWT_SECRET=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=



# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Company Certifications Configuration
CERTIFICATIONS_URL_MAX_LENGTH=500
CERTIFICATIONS_URL_VALIDATION_ENABLED=true
CERTIFICATIONS_URL_REQUIRED_FOR_AUFTRAGNEHMER=false
COMPANY_CERTIFICATIONS_URL_PATTERN=^https?://.*
COMPANY_CERTIFICATIONS_REQUIRED=false
COMPANY_VERIFICATION_STRICT_MODE=false

# Cloudinary Configuration
CLOUDINARY_URL=cloudinary://your-cloudinary-url